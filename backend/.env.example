# Hermes — Jada Agent Backend Environment
# Copy to .env and fill in your values.

# ── Required ────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...

# ── MCP Server Credentials ──────────────────────────────────────────
COMPOSIO_MCP_API_KEY=
VAULT_MCP_URL=http://72.62.86.63:8333/mcp
VAULT_MCP_BEARER_TOKEN=
PROTONMAIL_MCP_URL=https://protonmail.garzaos.online/mcp
PROTONMAIL_MCP_TOKEN=
NEXTCLOUD_MCP_URL=https://mcp-next.garzaos.online/mcp
# NEXTCLOUD_MCP_TOKEN=  # optional — only if your MCP server requires auth
# RUBE_MCP_TOKEN=       # optional — only if Rube is configured

# ── Auth ────────────────────────────────────────────────────────────
BEARER_TOKEN=jada-chat-2026

# ── Model ───────────────────────────────────────────────────────────
MODEL=qwen/qwen3.5-plus-02-15

# ── Telegram Bot (optional — omit to skip) ──────────────────────────
TELEGRAM_BOT_TOKEN=
# JADA_API_URL is set automatically in docker-compose (http://hermes:3200)
# JADA_BEARER_TOKEN defaults to BEARER_TOKEN value
